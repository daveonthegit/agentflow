{
  "name": "The same check failing across three distinct Runs is recurring",
  "kind": "recurring_check_failure",
  "min_runs": 3,
  "runs": [
    {
      "run_id": "fixture-run-1",
      "events": [
        {"sequence": 1, "type": "run_created"},
        {"sequence": 2, "type": "build_ready"},
        {"artifact": "checks-1.json", "sequence": 3, "type": "checks_failed"}
      ],
      "artifacts": {
        "checks-1.json": {
          "checks": [
            {"command": "python3 -m pytest tests/ -x -q", "returncode": 1},
            {"command": "python3 -m compileall -q src", "returncode": 0}
          ]
        }
      }
    },
    {
      "run_id": "fixture-run-2",
      "events": [
        {"sequence": 1, "type": "run_created"},
        {"sequence": 2, "type": "build_ready"},
        {"artifact": "checks-1.json", "sequence": 3, "type": "checks_failed"}
      ],
      "artifacts": {
        "checks-1.json": {
          "checks": [
            {"command": "python3 -m pytest tests/ -x -q", "returncode": 2}
          ]
        }
      }
    },
    {
      "run_id": "fixture-run-3",
      "events": [
        {"sequence": 1, "type": "run_created"},
        {"sequence": 2, "type": "build_ready"},
        {"artifact": "checks-1.json", "sequence": 3, "type": "checks_failed"}
      ],
      "artifacts": {
        "checks-1.json": {
          "checks": [
            {"command": "python3 -m pytest tests/ -x -q", "returncode": 1}
          ]
        }
      }
    }
  ],
  "expected_subjects": ["python3 -m pytest tests/ -x -q"]
}
